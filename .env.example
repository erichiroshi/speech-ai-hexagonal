SPEACHES_BASE_URL=http://localhost:8000
SPEACHES_MODEL=Systran/faster-whisper-small

SONAR_HOST_URL=https://sonarcloud.io
SONAR_TOKEN=

POSTGRES_DB=banco_de_dados
DB_URL=jdbc:postgresql://localhost:5432/banco_de_dados
DB_USERNAME=user
DB_PASSWORD=password

REDIS_HOST=localhost
REDIS_PORT=6379
CACHE_TTL=24

# Observabilidade
ZIPKIN_ENDPOINT=http://zipkin:9411/api/v2/spans
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Speech Provider
# speaches → Whisper local (padrão)
# openai   → OpenAI Whisper-1 cloud
SPEECH_PROVIDER=speaches

# OpenAI (necessário quando SPEECH_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=whisper-1

# Ollama (análise/resumo)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:1b
SUMMARY_TTL=72h

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Notification — Canais habilitados (true/false)
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_SMS_ENABLED=false
NOTIFICATION_WA_ENABLED=false
NOTIFICATION_NO_OP_ENABLED:true

# Destinatários
NOTIFICATION_EMAIL=user@example.com
NOTIFICATION_SMS_NUMBER=+5511999999999
NOTIFICATION_WHATSAPP_NUMBER=+5511999999999
NOTIFICATION_NO_OP_EMAIL=no_op@speech-ai.com

# E-mail (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFICATION_EMAIL_FROM=noreply@speech-ai.com

# SMS
SMS_PROVIDER_URL=
SMS_API_KEY=
SMS_FROM_NUMBER=

# WhatsApp
WA_PROVIDER_URL=
WA_API_KEY=
WA_FROM_NUMBER=
WA_PHONE_NUMBER_ID=
